{
  "name": "ampcloak",
  "version": "0.1.0",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run --allow-net --allow-write main.ts",
    "check": "deno check main.ts",
    "compile": "deno compile --allow-net --allow-write --output dist/ampcloak main.ts",
    "compile:all": "deno task compile:mac-arm && deno task compile:mac-x64 && deno task compile:linux && deno task compile:windows",
    "compile:mac-arm": "deno compile --allow-net --allow-write --target aarch64-apple-darwin --output dist/ampcloak-macos-arm64 main.ts",
    "compile:mac-x64": "deno compile --allow-net --allow-write --target x86_64-apple-darwin --output dist/ampcloak-macos-x64 main.ts",
    "compile:linux": "deno compile --allow-net --allow-write --target x86_64-unknown-linux-gnu --output dist/ampcloak-linux-x64 main.ts",
    "compile:windows": "deno compile --allow-net --allow-write --target x86_64-pc-windows-msvc --output dist/ampcloak-windows-x64.exe main.ts"
  },
  "imports": {
    "@b-fuze/deno-dom": "jsr:@b-fuze/deno-dom@^0.1.49",
    "@std/cli": "jsr:@std/cli@^1.0.17",
    "@std/fmt": "jsr:@std/fmt@^1.0.8"
  },
  "fmt": {
    "lineWidth": 100
  }
}
